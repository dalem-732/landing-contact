# ── Общие настройки приложения ─────────────────────────────
APP_NAME="Landing Contact Service"
APP_ENV=development              # development | staging | production
DEBUG=true
LOG_FORMAT=text                  # text | json
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true      # auto-disabled when CORS_ORIGINS=*

# ── Trusted proxy (IP через запятую) ─────────────────────
# X-Forwarded-For доверяется только если прямой IP в этом списке.
TRUSTED_PROXY_IPS=

# ── Rate limiting — IP ────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# ── Rate limiting — email ─────────────────────────────────
RATE_LIMIT_EMAIL_MAX=3
RATE_LIMIT_EMAIL_WINDOW=3600

# ── Validation ────────────────────────────────────────────
DEFAULT_PHONE_REGION=RU

# ── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://landing:landing@localhost:5432/landing
DB_POOL_SIZE=5
DB_ECHO=false

# ── Redis (rate limit + ARQ email queue) ──────────────────
REDIS_URL=

# ── Email / SMTP ──────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM="Landing Bot <no-reply@example.com>"
OWNER_EMAIL=owner@example.com

# ── AI ────────────────────────────────────────────────────
AI_PROVIDER=openai
AI_TIMEOUT_SECONDS=15
AI_CIRCUIT_FAILURE_THRESHOLD=3
AI_CIRCUIT_COOLDOWN_SECONDS=300

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ── Cloudflare Turnstile CAPTCHA ──────────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
